APP_NAME=Checkout
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://checkout.example.com

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=checkout
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Gateway: Asaas (default)
DEFAULT_GATEWAY=asaas
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=production
ASAAS_WEBHOOK_TOKEN=

# Auth
CHECKOUT_AUTH_GUARD=token

# Queue
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@checkout.example.com
MAIL_FROM_NAME="${APP_NAME}"
