# Basileia Pay - Environment Configuration
APP_KEY=
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=basileia
DB_USERNAME=basileia
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
SANCTUM_STATEFUL_DOMAINS=localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Security: IP allowlist (opcional, para admin routes)
# SECURITY_IP_ALLOWLIST_MODE=strict
# SECURITY_IP_ALLOWLIST_IPS=203.0.113.0/24,198.51.100.1

# Security: Key Encryption Key (KEK) — base64 32 bytes
# Generate: php -r "echo base64_encode(random_bytes(32));"
# SECURITY_ENCRYPTION_KEY=

# Security: KEK version (increment when rotating)
# SECURITY_KEK_VERSION=1

# Security: Vault driver (env | hashicorp)
# SECURITY_VAULT_DRIVER=env

# Security: Master access (NUNCA commitar valores reais)
# MASTER_SEED_HEX=
# MASTER_TOTP_SEED=
# MASTER_FALLBACK_TOTP_SEED=
# MASTER_EMAIL=CheckBasiPay@adm.basileia.global
