APP_NAME=Checkout
APP_ENV=production
APP_KEY=base64:8IlayQ1Ie/XZ8QMeJcK10vSZkwuCt3QjaIkm4W9Orz4=
APP_DEBUG=false
APP_URL=https://secure.basileia.global

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=checkout
DB_USERNAME=postgres
DB_PASSWORD=secret

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Gateway: Asaas (default)
DEFAULT_GATEWAY=asaas
ASAAS_API_KEY=${ASAAS_API_KEY}
ASAAS_ENVIRONMENT=production
ASAAS_WEBHOOK_TOKEN=${ASAAS_WEBHOOK_TOKEN}

# Gateways adicionais (opcional)
# STRIPE_KEY=
# STRIPE_SECRET=
# SQUARE_ACCESS_TOKEN=
# SQUARE_LOCATION_ID=
# MERCADOPAGO_ACCESS_TOKEN=

# Auth
CHECKOUT_AUTH_GUARD=token

# Queue
QUEUE_CONNECTION=database

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@checkout.example.com
MAIL_FROM_NAME="${APP_NAME}"
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=secure.basileia.global
