APP_NAME="Basileia Pay"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://secure.basileia.global

# ─── Security ───────────────────────────────────────────────────────────
# Chave de criptografia para credenciais de gateway (AES-256-GCM)
# Gerar: php -r "echo 'base64:' . base64_encode(random_bytes(32));"
SECURITY_ENCRYPTION_KEY=

# Salt para hash de IPs nos audit logs (LGPD)
SECURITY_IP_SALT=

# ─── Database ───────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=checkout
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Session / Cache / Queue ────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.basileia.global
CACHE_STORE=database
QUEUE_CONNECTION=database

# ─── Gateway: Asaas ─────────────────────────────────────────────────────
DEFAULT_GATEWAY=asaas
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=production
ASAAS_WEBHOOK_TOKEN=

# ─── Gateways adicionais (opcional) ─────────────────────────────────────
# STRIPE_KEY=
# STRIPE_SECRET=
# MERCADOPAGO_ACCESS_TOKEN=

# ─── Master Access ─────────────────────────────────────────────────────────
# Seed para TOTP do super master (gerar: php artisan master:generate-seed)
# NUNCA compartilhe ou comite este valor
MASTER_TOTP_SEED=

# ─── Auth ────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8080,127.0.0.1,127.0.0.1:8000,::1,secure.basileia.global

# ─── Mail ────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@basileia.global
MAIL_FROM_NAME="${APP_NAME}"